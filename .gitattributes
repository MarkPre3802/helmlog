# Force LF line endings for files that must run on Linux/Pi
*.sh        text eol=lf
*.service   text eol=lf
*.py        text eol=lf
*.conf      text eol=lf
*.yaml      text eol=lf
*.yml       text eol=lf
*.toml      text eol=lf
*.md        text eol=lf
*.txt       text eol=lf
*.html      text eol=lf
*.css       text eol=lf
*.js        text eol=lf

# Binaries — no line ending conversion
*.png       binary
*.jpg       binary
*.jpeg      binary
*.gif       binary
*.ico       binary
*.db        binary
*.sqlite    binary
